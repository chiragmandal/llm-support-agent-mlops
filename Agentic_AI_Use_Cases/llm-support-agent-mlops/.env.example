# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed.

# --- Infrastructure ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=support_kb

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

MLFLOW_TRACKING_URI=http://127.0.0.1:5001

# --- Embedding ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking ---
CHUNK_SIZE_CHARS=1100
CHUNK_OVERLAP_CHARS=180

# --- Retrieval ---
TOP_K=5
# Discard retrieved chunks with cosine similarity below this value.
SCORE_THRESHOLD=0.30

# --- API safety ---
# Hard cap on incoming ticket length (characters).
MAX_TICKET_CHARS=2000

# --- Ollama reliability ---
OLLAMA_TIMEOUT_S=120
OLLAMA_RETRIES=3

# --- Quality gates ---
GATE_CITATION_RATE=0.90
GATE_GROUNDEDNESS=0.55
GATE_P95_LAT_MS=20000
